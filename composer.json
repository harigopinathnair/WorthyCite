{
    "name": "harig/worthycite",
    "description": "Worthycite SEO Platform",
    "type": "project",
    "require": {
        "php": ">=8.2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "classmap": [
            "controllers/",
            "models/",
            "core/",
            "config/"
        ]
    },
    "config": {
        "process-timeout": 600,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
